# Groq API Configuration (БЕЗПЛАТЕН - без платежна карта!)
# ====================================

# Groq API ключ - Получи го от https://console.groq.com
GROQ_API_KEY=gsk_your_api_key_here

# Groq Model - Проверь актуалните модели тук: https://console.groq.com/docs/models
# Препоръченото: llama-3.2-90b-vision-preview, deepseek-r1-distill-llama-70b
GROQ_MODEL=llama-3.2-90b-vision-preview

# Портъл на сървъра
PORT=3000
